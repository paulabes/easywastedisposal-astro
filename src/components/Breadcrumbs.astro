---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const BASE_URL = 'https://easywastedisposal.co.uk';

const schemaItems = items.map((item, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: item.label,
  ...(item.href ? { item: `${BASE_URL}${item.href}` } : {}),
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav aria-label="Breadcrumb" class="relative z-10">
  <div class="px-4 sm:px-6 lg:px-8 pt-6">
    <ol class="flex items-center space-x-1 text-xs text-white/60">
      {items.map((item, i) => (
        <li class="flex items-center">
          {i > 0 && (
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-1 text-white/40 flex-shrink-0"><path d="m9 18 6-6-6-6"/></svg>
          )}
          {item.href ? (
            <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
          ) : (
            <span class="text-white/80">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
