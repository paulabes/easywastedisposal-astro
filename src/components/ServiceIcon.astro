---
import { serviceIconSVG } from '../data/service-icons';

interface Props {
  slug: string;
  size?: number;
  class?: string;
}

const { slug, size = 24, class: className = '' } = Astro.props;
const svgContent = serviceIconSVG[slug] || '';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  set:html={svgContent}
/>
