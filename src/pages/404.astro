---
import Layout from '../layouts/Layout.astro';
import { businessInfo } from '../data/locations';
---

<Layout
  title="Page Not Found | Easy Waste Disposal"
  description="The page you're looking for doesn't exist. Browse our waste disposal services or get in touch."
  hideFooterCTA={true}
>
  <section class="bg-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <div class="absolute top-20 right-20 w-[500px] h-[500px] bg-green-500 rounded-full blur-[150px]"></div>
      <div class="absolute bottom-10 left-10 w-[400px] h-[400px] bg-green-400 rounded-full blur-[120px]"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-24 lg:py-32">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-green-400 font-extrabold text-7xl lg:text-9xl mb-6 tracking-tight">404</p>
        <h1 class="text-3xl lg:text-4xl font-extrabold text-white mb-4 tracking-tight">Page not found</h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-10 font-medium">
          Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists.
        </p>
        <div class="flex flex-row justify-center gap-3">
          <a href="/">
            <button class="inline-flex items-center justify-center font-bold tracking-wide transition-all duration-300 rounded-2xl bg-green-600 text-white hover:bg-green-500 shadow-md border border-green-500 px-5 py-3 text-sm hover:-translate-y-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Go home
            </button>
          </a>
          <a href="/services">
            <button class="inline-flex items-center justify-center font-bold tracking-wide transition-all duration-300 rounded-2xl bg-white text-dark hover:bg-gray-50 shadow-md border border-gray-200 px-5 py-3 text-sm hover:-translate-y-0.5">
              View services
            </button>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
