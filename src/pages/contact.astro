---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { QuoteForm } from '../components/QuoteForm';
import { GoogleReviewsReact } from '../components/GoogleReviewsReact';
import { businessInfo } from '../data/locations';
import { heroImage } from '../data/images';
---

<Layout
  title="Get a Free Quote | Same-Day Waste Collection London"
  description="Request a free waste disposal quote. Same-day and next-day collection across London. Call 07342 877 759 or fill in our quick form. We respond shortly."
  canonical="/contact"
  hideFooterCTA={true}
>
  <div class="space-y-0">
    <!-- Hero Section -->
    <section class="bg-dark relative overflow-hidden">
      <div class="absolute inset-0">
        <img src={heroImage} alt="" class="w-full h-full object-cover opacity-10 filter grayscale mix-blend-overlay" />
      </div>
      <div class="absolute inset-0 opacity-15">
        <div class="absolute top-20 right-20 w-[500px] h-[500px] bg-green-500 rounded-full blur-[150px]"></div>
        <div class="absolute bottom-10 left-10 w-[400px] h-[400px] bg-green-400 rounded-full blur-[120px]"></div>
      </div>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-10 lg:py-20">
        <div class="max-w-3xl mx-auto text-center text-white">
          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-extrabold leading-tight mb-6 tracking-tight">
            Get your <span class="text-green-400">free quote</span>
          </h1>
          <p class="text-lg lg:text-xl text-gray-300 leading-relaxed font-medium mb-8">
            Fill in the form below, call us, or send a WhatsApp message. We'll get back to you shortly with a no-obligation quote.
          </p>
          <a href={businessInfo.googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center space-x-2 hover:opacity-80 transition-opacity">
            <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            <div class="flex">{[1,2,3,4,5].map(() => (<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#facc15" stroke="#facc15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>))}</div>
            <span class="text-sm font-bold text-white">{businessInfo.rating}</span>
            <span class="text-xs text-gray-300 font-medium">{businessInfo.reviewCount}+ Google Reviews</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Quote Form + Sidebar Section -->
    <section id="quote" class="bg-gray-100 py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          <!-- Quote Form -->
          <div class="lg:col-span-2">
            <QuoteForm client:load />
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            <!-- Our Details Card -->
            <div class="bg-white rounded-2xl p-6 shadow-sm">
              <h2 class="text-lg font-bold text-gray-900 mb-4">Our details</h2>
              <div class="space-y-4">
                <div class="flex items-start space-x-3">
                  <!-- MapPin icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 flex-shrink-0 mt-0.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="text-gray-700 text-sm">52B Turnpike Lane<br />London, N8 0PS</span>
                </div>
                <div class="flex items-start space-x-3">
                  <!-- Clock icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600 flex-shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span class="text-gray-700 text-sm">{businessInfo.hours}</span>
                </div>
              </div>
            </div>

            <!-- Contact Us Directly Card -->
            <div class="bg-white rounded-2xl p-6 shadow-sm">
              <h2 class="text-lg font-bold text-gray-900 mb-4">Contact us directly</h2>
              <div class="space-y-3">
                <a href={businessInfo.phoneHref} class="flex items-center space-x-3 text-gray-700 hover:text-green-600 transition-colors group">
                  <!-- Phone icon -->
                  <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center group-hover:bg-green-100 transition-colors flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <span class="font-semibold text-sm">{businessInfo.phone}</span>
                </a>
                <a href={businessInfo.whatsapp} target="_blank" rel="noopener noreferrer" class="flex items-center space-x-3 text-gray-700 hover:text-green-600 transition-colors group">
                  <!-- MessageCircle icon -->
                  <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center group-hover:bg-green-100 transition-colors flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                  </div>
                  <span class="font-semibold text-sm">WhatsApp us</span>
                </a>
              </div>
            </div>

            <!-- Trust Card -->
            <div class="bg-dark rounded-2xl p-6 text-white">
              <div class="mb-5">
                <GoogleReviewsReact size="md" dark client:load />
              </div>
              <div class="space-y-3">
                <div class="flex items-center space-x-3">
                  <!-- CheckCircle2 icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 flex-shrink-0"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  <span class="text-sm text-gray-300">Licence number: {businessInfo.licenceNumber}</span>
                </div>
                <div class="flex items-center space-x-3">
                  <!-- CheckCircle2 icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 flex-shrink-0"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  <span class="text-sm text-gray-300">Fully insured</span>
                </div>
                <div class="flex items-center space-x-3">
                  <!-- CheckCircle2 icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-400 flex-shrink-0"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  <span class="text-sm text-gray-300">Price-match guarantee</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
